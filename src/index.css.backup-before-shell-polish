:root {
  --text: #6b6375;
  --text-h: #08060d;
  --bg: #fff;
  --border: #e5e4e7;
  --code-bg: #f4f3ec;
  --accent: #aa3bff;
  --accent-bg: rgba(170, 59, 255, 0.1);
  --accent-border: rgba(170, 59, 255, 0.5);
  --social-bg: rgba(244, 243, 236, 0.5);
  --shadow:
    rgba(0, 0, 0, 0.1) 0 10px 15px -3px, rgba(0, 0, 0, 0.05) 0 4px 6px -2px;

  --sans: system-ui, 'Segoe UI', Roboto, sans-serif;
  --heading: system-ui, 'Segoe UI', Roboto, sans-serif;
  --mono: ui-monospace, Consolas, monospace;

  font: 18px/145% var(--sans);
  letter-spacing: 0.18px;
  color-scheme: light dark;
  color: var(--text);
  background: var(--bg);
  font-synthesis: none;
  text-rendering: optimizeLegibility;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;

  @media (max-width: 1024px) {
    font-size: 16px;
  }
}

@media (prefers-color-scheme: dark) {
  :root {
    --text: #9ca3af;
    --text-h: #f3f4f6;
    --bg: #16171d;
    --border: #2e303a;
    --code-bg: #1f2028;
    --accent: #c084fc;
    --accent-bg: rgba(192, 132, 252, 0.15);
    --accent-border: rgba(192, 132, 252, 0.5);
    --social-bg: rgba(47, 48, 58, 0.5);
    --shadow:
      rgba(0, 0, 0, 0.4) 0 10px 15px -3px, rgba(0, 0, 0, 0.25) 0 4px 6px -2px;
  }

  #social .button-icon {
    filter: invert(1) brightness(2);
  }
}

body {
  margin: 0;
}

#root {
  width: 1126px;
  max-width: 100%;
  margin: 0 auto;
  text-align: center;
  border-inline: 1px solid var(--border);
  min-height: 100svh;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
}

h1,
h2 {
  font-family: var(--heading);
  font-weight: 500;
  color: var(--text-h);
}

h1 {
  font-size: 56px;
  letter-spacing: -1.68px;
  margin: 32px 0;
  @media (max-width: 1024px) {
    font-size: 36px;
    margin: 20px 0;
  }
}
h2 {
  font-size: 24px;
  line-height: 118%;
  letter-spacing: -0.24px;
  margin: 0 0 8px;
  @media (max-width: 1024px) {
    font-size: 20px;
  }
}
p {
  margin: 0;
}

code,
.counter {
  font-family: var(--mono);
  display: inline-flex;
  border-radius: 4px;
  color: var(--text-h);
}

code {
  font-size: 15px;
  line-height: 135%;
  padding: 4px 8px;
  background: var(--code-bg);
}

.dashboard-grid {
  display: grid;
  grid-template-columns:
    repeat(auto-fit, minmax(220px, 1fr));
  gap: 20px;
  margin-top: 20px;
}

.summary-card {
  padding: 24px;
  border-radius: 12px;
  border: 1px solid #ddd;
  background: white;
}

.summary-card h3 {
  margin-bottom: 12px;
}

.summary-card h2 {
  margin: 0;
}

/* Active Alerts Dashboard */
.alerts-page {
  width: min(1120px, 100%);
  margin: 0 auto;
  padding: 24px;
}

.page-hero {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24px;
  padding: 28px;
  margin-bottom: 24px;
  border: 1px solid #e5e7eb;
  border-radius: 24px;
  background:
    radial-gradient(circle at top left, rgba(59, 130, 246, 0.12), transparent 32%),
    linear-gradient(135deg, #ffffff, #f8fafc);
  box-shadow: 0 20px 45px rgba(15, 23, 42, 0.08);
}

.page-hero h2 {
  margin: 0;
  font-size: 44px;
  letter-spacing: -0.04em;
  color: #0f172a;
}

.page-hero p {
  margin: 8px 0 0;
  color: #64748b;
  font-size: 16px;
}

.eyebrow {
  margin: 0 0 8px !important;
  color: #2563eb !important;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 0.14em;
  font-size: 12px !important;
}

.primary-action {
  border: 0;
  border-radius: 999px;
  padding: 12px 18px;
  background: #2563eb;
  color: #ffffff;
  font-weight: 800;
  cursor: pointer;
  box-shadow: 0 12px 24px rgba(37, 99, 235, 0.28);
}

.primary-action:hover {
  background: #1d4ed8;
}

.alert-summary-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 16px;
  margin-bottom: 24px;
}

.alert-summary-card {
  padding: 22px;
  border-radius: 22px;
  border: 1px solid #e5e7eb;
  background: #ffffff;
  box-shadow: 0 16px 35px rgba(15, 23, 42, 0.07);
}

.alert-summary-card span {
  display: block;
  color: #64748b;
  font-weight: 700;
  margin-bottom: 12px;
}

.alert-summary-card strong {
  display: block;
  font-size: 34px;
  color: #0f172a;
}

.alert-summary-card.high {
  border-color: #fecaca;
  background: #fff7f7;
}

.alert-summary-card.medium {
  border-color: #fde68a;
  background: #fffbeb;
}

.alert-summary-card.low {
  border-color: #bbf7d0;
  background: #f0fdf4;
}

.incident-list {
  display: grid;
  gap: 16px;
}

.incident-card {
  padding: 24px;
  border-radius: 24px;
  border: 1px solid #e5e7eb;
  background: #ffffff;
  box-shadow: 0 18px 38px rgba(15, 23, 42, 0.08);
}

.incident-card-header {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 14px;
}

.severity-badge {
  display: inline-flex;
  align-items: center;
  border-radius: 999px;
  padding: 7px 12px;
  font-weight: 900;
  font-size: 12px;
  letter-spacing: 0.08em;
}

.severity-badge.high {
  background: #fee2e2;
  color: #991b1b;
}

.severity-badge.medium {
  background: #fef3c7;
  color: #92400e;
}

.severity-badge.low {
  background: #dcfce7;
  color: #166534;
}

.incident-type {
  font-weight: 900;
  color: #0f172a;
  letter-spacing: 0.04em;
}

.incident-message {
  margin: 0 0 20px;
  font-size: 18px;
  color: #334155;
}

.incident-meta-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14px;
  margin-bottom: 20px;
}

.incident-meta-grid div {
  padding: 14px;
  border-radius: 16px;
  background: #f8fafc;
}

.incident-meta-grid span {
  display: block;
  margin-bottom: 6px;
  color: #64748b;
  font-size: 12px;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 0.08em;
}

.incident-meta-grid strong {
  color: #0f172a;
  word-break: break-word;
}

.incident-actions {
  display: flex;
  justify-content: flex-end;
}

.resolve-button {
  border: 0;
  border-radius: 999px;
  padding: 10px 16px;
  background: #0f172a;
  color: white;
  font-weight: 800;
  cursor: pointer;
}

.resolve-button:hover {
  background: #1e293b;
}

.resolve-button:disabled {
  cursor: not-allowed;
  opacity: 0.6;
}

.alert-empty,
.alert-error {
  padding: 34px;
  border-radius: 24px;
  text-align: center;
  border: 1px solid #e5e7eb;
  background: #ffffff;
  box-shadow: 0 18px 38px rgba(15, 23, 42, 0.08);
}

.alert-error {
  border-color: #fecaca;
  background: #fff7f7;
  color: #991b1b;
}

.alert-error button {
  border: 0;
  border-radius: 999px;
  padding: 10px 16px;
  background: #991b1b;
  color: white;
  font-weight: 800;
  cursor: pointer;
}

.empty-icon {
  width: 54px;
  height: 54px;
  display: grid;
  place-items: center;
  margin: 0 auto 14px;
  border-radius: 999px;
  background: #dcfce7;
  color: #166534;
  font-size: 28px;
  font-weight: 900;
}

.alert-skeleton-grid {
  display: grid;
  gap: 16px;
}

.alert-skeleton {
  height: 150px;
  border-radius: 24px;
  background: linear-gradient(90deg, #f1f5f9, #e2e8f0, #f1f5f9);
  background-size: 200% 100%;
  animation: alertPulse 1.3s infinite;
}

@keyframes alertPulse {
  0% {
    background-position: 200% 0;
  }

  100% {
    background-position: -200% 0;
  }
}

@media (max-width: 900px) {
  .page-hero {
    align-items: flex-start;
    flex-direction: column;
  }

  .alert-summary-grid,
  .incident-meta-grid {
    grid-template-columns: 1fr;
  }

  .page-hero h2 {
    font-size: 34px;
  }
}

/* System Overview Dashboard */
.overview-page {
  width: min(1120px, 100%);
  margin: 0 auto;
  padding: 24px;
}

.overview-hero {
  padding: 32px;
  margin-bottom: 24px;
  border: 1px solid #e5e7eb;
  border-radius: 28px;
  background:
    radial-gradient(circle at top left, rgba(37, 99, 235, 0.14), transparent 34%),
    linear-gradient(135deg, #ffffff, #f8fafc);
  box-shadow: 0 20px 45px rgba(15, 23, 42, 0.08);
}

.overview-hero h1 {
  margin: 0;
  color: #0f172a;
  font-size: 48px;
  letter-spacing: -0.05em;
}

.overview-hero p {
  margin: 10px 0 0;
  color: #64748b;
  font-size: 16px;
}

.overview-warning {
  margin-bottom: 20px;
  padding: 16px 18px;
  border-radius: 18px;
  border: 1px solid #fde68a;
  background: #fffbeb;
  color: #92400e;
  font-weight: 800;
}

.overview-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(160px, 1fr));
  gap: 18px;
}

.overview-card {
  min-height: 130px;
  padding: 24px;
  border: 1px solid #e5e7eb;
  border-radius: 24px;
  background: #ffffff;
  box-shadow: 0 18px 38px rgba(15, 23, 42, 0.08);
}

.overview-card span {
  display: block;
  color: #64748b;
  font-weight: 800;
  font-size: 14px;
}

.overview-card strong {
  display: block;
  margin-top: 18px;
  color: #0f172a;
  font-size: 42px;
  line-height: 1;
}

.overview-card.success {
  border-color: #bbf7d0;
  background: #f0fdf4;
}

.overview-card.danger {
  border-color: #fecaca;
  background: #fff7f7;
}

.overview-card.warning {
  border-color: #fde68a;
  background: #fffbeb;
}

@media (max-width: 1000px) {
  .overview-grid {
    grid-template-columns: repeat(2, minmax(160px, 1fr));
  }
}

@media (max-width: 640px) {
  .overview-grid {
    grid-template-columns: 1fr;
  }

  .overview-hero h1 {
    font-size: 36px;
  }
}

.devices-page,
.telemetry-page {
  width: min(1120px, 100%);
  margin: 0 auto;
  padding: 24px;
}

.device-status {
  display: inline-flex;
  align-items: center;
  border-radius: 999px;
  padding: 7px 12px;
  font-weight: 900;
  font-size: 12px;
  letter-spacing: 0.08em;
}

.device-status.online {
  background: #dcfce7;
  color: #166534;
}

.device-status.offline {
  background: #fee2e2;
  color: #991b1b;
}

.device-status.unknown {
  background: #e5e7eb;
  color: #374151;
}
